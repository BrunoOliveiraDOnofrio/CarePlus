meta {
  name: Listar Pacientes
  type: http
  seq: 8
}

get {
  url: http://localhost:8080/pacientes/todos-pacientes-funcionario?pagina=0&idFuncionario=5
  body: none
  auth: bearer
}

params:query {
  pagina: 0
  idFuncionario: 5
}

auth:bearer {
  token: {{tokenId}}
}

settings {
  encodeUrl: true
  timeout: 0
}
