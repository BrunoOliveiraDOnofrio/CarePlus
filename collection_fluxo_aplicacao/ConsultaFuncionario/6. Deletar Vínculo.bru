meta {
  name: 6. Deletar Vínculo
  type: http
  seq: 6
}

delete {
  url: {{baseUrl}}/consulta-funcionario/1
  body: none
  auth: bearer
}

auth:bearer {
  token: {{tokenId}}
}

docs {
  Remove um vínculo entre consulta e funcionário pelo id do registro ConsultaFuncionario.
  Para desvincular um funcionário de uma consulta, basta deletar o registro desta tabela.
  Retorna 204 em caso de sucesso, 404 se o vínculo não existir.
}

