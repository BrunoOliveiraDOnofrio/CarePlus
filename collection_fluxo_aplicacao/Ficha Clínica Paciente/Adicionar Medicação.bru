meta {
  name: Adicionar Medicação
  type: http
  seq: 12
}

post {
  url: {{baseUrl}}/medicacoes?id=1
  body: json
  auth: bearer
}

params:query {
  id: 1
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "nomeMedicacao": "Luftal",
    "dataInicio": "2026-04-21",
    "dataFim": "2026-04-21",
    "ativo": true,
    "idProntuario": 1
  }
}
