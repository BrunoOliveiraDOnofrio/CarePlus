meta {
  name: Atualizar Tratamento
  type: http
  seq: 4
}

put {
  url: {{baseUrl}}/detalhes-pacientes/tratamento?id=1
  body: json
  auth: bearer
}

auth:bearer {
  token: {{tokenId}}
}

body:json {
  {
    "tipoDeTratamento": "Terapia Fonoaudiológica",
    "finalizado": true,
    "idFichaClinica": 1
  }
}
