meta {
  name: Listar Consultas
  type: http
  seq: 8
}

get {
  url: http://localhost:8080/consultas-prontuario
  body: none
  auth: bearer
}

headers {
  Authorization: Bearer <YOUR_JWT_TOKEN>
  Accept: application/json
}

auth:bearer {
  token: {{tokenId}}
}

settings {
  encodeUrl: false
  timeout: 0
}
